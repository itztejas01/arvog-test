# Encode special characters in the password (e.g. # → %23, @ → %40)
DATABASE_URL="postgresql://appuser:apppassword@localhost:5432/avrogdb?schema=public"
JWT_SECRET="change-me-in-production"
PORT=3000

# Optional: enable S3 storage for serverless (omit for local disk uploads)
# AWS_REGION=us-east-1
# AWS_S3_BUCKET=avrog-assets-dev
# AWS_CLOUDFRONT_URL=https://d1234abcd.cloudfront.net
